# --- Comunes (Sección 7.3) ---
# Legacy/no usadas por el runtime actual (local y producción)
# DJANGO_SECRET_KEY=
# Docker Compose (servicio postgres): usar host `postgres` y puerto interno 5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/smartbooking
REDIS_URL=redis://<host>:<port>
# TIMEZONE=UTC

# --- Integraciones (sandbox en staging) ---
META_WABA_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Telegram + túnel local (perfil ngrok en docker-compose)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
AUTO_TOKEN_NGROK=

# Si `docker compose` falla por puertos ocupados en el host:
# API_BACKEND_HOST_PORT=18008
# NGINX_HOST_PORT=18080

# --- Backend (puertos/comandos opcionales) ---
# PORT=8000

# --- Agent Service ---
# AGENT_PORT=8000

# --- Frontend (Vite) ---
VITE_API_BASE_URL=https://<staging-backend>/api/v1
# VITE_AGENT_URL=https://<staging-agent>/
# VITE_MAPS_API_KEY=
