# Base de datos (asyncpg)
# Host + Postgres en Docker (docker-compose: puerto 5435 -> 5432):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5435/smartbooking
# Dentro de Docker Compose (servicio api-backend):
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/smartbooking
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/smartbooking

JWT_SECRET_KEY=change-me-in-production

# Registro: false exige verificación por correo (SMTP pendiente en el proyecto)
AUTO_VERIFY_EMAIL=true

# Telegram (un solo bot multi-tenant)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# OpenAI / Meta / Sentry (opcional)
OPENAI_API_KEY=
META_WABA_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
SENTRY_DSN=

ALLOWED_ORIGINS=http://localhost:5173

# Enlaces en correos (verificación)
FRONTEND_BASE_URL=http://localhost:5173

# SMTP (vacío = solo log del enlace en servidor)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
SMTP_USE_TLS=true

# Redis opcional: rate limits compartidos (resend + intentos Telegram)
# REDIS_URL=redis://localhost:6379/0

# Límites diarios por usuario-negocio (optimización tokens)
TG_DAILY_TOTAL_LIMIT=40
TG_DAILY_AI_LIMIT=12
# Pruebas: true desactiva cuotas Telegram/WhatsApp y el rate limit HTTP por IP
DISABLE_USAGE_LIMITS=false
# Fallback persistente local cuando no hay Redis
# RATE_LIMIT_STATE_FILE=/tmp/smartbooking_daily_quotas.json
