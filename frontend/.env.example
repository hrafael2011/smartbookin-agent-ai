# API: en desarrollo usar /api + proxy en vite.config (evita CORS). En build Docker: /api
VITE_API_URL=/api
# Target del proxy (Nginx del repo en docker-compose; si usás 8080 u otro puerto, cambiá aquí)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:18080

# App Configuration
# Legacy/no usadas por el frontend actual
# VITE_APP_NAME=SmartBooking AI
# VITE_APP_DESCRIPTION=Sistema de agendamiento inteligente con WhatsApp
